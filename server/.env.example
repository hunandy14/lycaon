# AI 規則助手：Cloudflare Workers AI 的 OpenAI 相容端點（複製為 server/.env 填入真金鑰；server/.env 已 gitignored）
AI_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1
AI_TOKEN=<CLOUDFLARE_API_TOKEN>
AI_MODEL=@cf/zai-org/glm-4.7-flash
# 關閉 GLM 的 thinking 模式，大幅降低首字延遲（14–23 秒 → 1–3 秒）；'1' 或 'true' 開啟，其餘值/未設定=維持預設 thinking
AI_DISABLE_THINKING=1
